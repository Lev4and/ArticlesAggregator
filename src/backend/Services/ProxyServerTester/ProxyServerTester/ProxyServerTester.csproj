<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <DocumentationFile>ProxyServerTester.xml</DocumentationFile>
        <NoWarn>$(NoWarn);1591</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" />
    </ItemGroup>

    <ItemGroup>
      <Content Include="..\..\..\..\..\.dockerignore">
        <Link>.dockerignore</Link>
      </Content>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\..\BuildingBlocks\Observability.OpenTelemetry\Observability.OpenTelemetry.csproj" />
      <ProjectReference Include="..\..\..\BuildingBlocks\Server.Kestrel\Server.Kestrel.csproj" />
      <ProjectReference Include="..\ProxyServerTester.Application\ProxyServerTester.Application.csproj" />
      <ProjectReference Include="..\ProxyServerTester.Domain\ProxyServerTester.Domain.csproj" />
      <ProjectReference Include="..\ProxyServerTester.Infrastructure\ProxyServerTester.Infrastructure.csproj" />
      <ProjectReference Include="..\ProxyServerTester.Persistence\ProxyServerTester.Persistence.csproj" />
      <ProjectReference Include="..\ProxyServerTester.Presentation\ProxyServerTester.Presentation.csproj" />
    </ItemGroup>

</Project>
